{
  "name": "game-outreach-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:init": "wrangler d1 execute game-outreach-mcp-db --file=./migrations/0001_initial.sql",
    "db:init:remote": "wrangler d1 execute game-outreach-mcp-db --file=./migrations/0001_initial.sql --remote",
    "db:init:preview": "wrangler d1 execute game-outreach-mcp-db-preview --file=./migrations/0001_initial.sql --env preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5",
    "wrangler": "^3.80.0"
  }
}
